# The demo is fully local by default and needs no credentials.
# A comma-separated allow-list for the browser development server.
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Set this only when a production music integration supplies its own derived
# reference contour. Do not put music-service cookies or API secrets here.
# REFERENCE_CONTOUR_DIRECTORY=./data/reference-contours
